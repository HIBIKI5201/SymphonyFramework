<ui:UXML xmlns:ui="UnityEngine.UIElements" noNamespaceSchemaLocation="../../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/SymphonyFrameWork/Editor/Administrator/UITK/SymphonyWIndow.uss?fileID=7433441132597879392&amp;guid=16c3f611d15eda644b63e276b16e6925&amp;type=3#SymphonyWIndow"/>
    <ui:VisualElement class="base">
        <ui:Label text="Save Data Registry" class="title"/>
        <ui:Label name="save-current-loader" text="Current Loader:" class="text" style="margin-top: 6px;"/>
        <ui:Label name="save-loaded-entries" text="Loaded Entries:" class="text" style="margin-bottom: 8px;"/>

        <ui:VisualElement style="width: 100%; flex-direction: row; margin-bottom: 8px;">
            <ui:Button name="save-refresh-types" text="Refresh Types" class="button" style="flex-grow: 1; height: 32px;"/>
            <ui:Button name="save-refresh-loader" text="Refresh Loader" class="button" style="flex-grow: 1; height: 32px;"/>
        </ui:VisualElement>

        <ui:Label text="Save Data Type" class="text" style="-unity-text-align: middle-left; width: 100%;"/>
        <ui:DropdownField name="save-type-dropdown" class="text" style="width: 100%; margin-top: 4px; margin-bottom: 8px;"/>

        <ui:VisualElement style="width: 100%; flex-direction: row; flex-wrap: wrap; margin-bottom: 8px;">
            <ui:Button name="save-new" text="New" class="button" style="width: 32%; height: 32px;"/>
            <ui:Button name="save-load" text="Load" class="button" style="width: 32%; height: 32px;"/>
            <ui:Button name="save-save" text="Save" class="button" style="width: 32%; height: 32px;"/>
            <ui:Button name="save-unload" text="Unload" class="button" style="width: 48.5%; height: 32px;"/>
            <ui:Button name="save-delete" text="Delete" class="button" style="width: 48.5%; height: 32px;"/>
        </ui:VisualElement>

        <ui:Label text="Status" class="text" style="-unity-text-align: middle-left; width: 100%;"/>
        <ui:Label name="save-status" text="Type を選択して Load してください。" class="text" style="-unity-text-align: upper-left; width: 100%; white-space: normal; margin-top: 4px; margin-bottom: 8px;"/>

        <ui:IMGUIContainer name="save-editor" style="width: 100%; margin-bottom: 10px;"/>

        <ui:Label text="Registry Cache" class="text" style="-unity-text-align: middle-left; width: 100%;"/>
        <ui:ListView name="save-cache-list" fixed-item-height="42" class="text" style="width: 100%; height: 180px; margin-top: 6px; border-top-width: 1px; border-right-width: 1px; border-bottom-width: 1px; border-left-width: 1px; border-left-color: rgb(0, 0, 0); border-right-color: rgb(0, 0, 0); border-top-color: rgb(0, 0, 0); border-bottom-color: rgb(0, 0, 0);"/>
    </ui:VisualElement>
</ui:UXML>
